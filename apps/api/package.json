{
  "name": "@marketing-funnel/api",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "seed": "ts-node src/orgs/afluence/company-1/seed.ts",
    "seed:german-roz": "ts-node src/orgs/german-roz/main/seed.ts",
    "seed:german-roz-plan-90-pro": "ts-node src/orgs/german-roz/plan-90-pro/seed.ts",
    "seed:lucas-con-lucas": "ts-node src/orgs/lucas-con-lucas/main/seed.ts",
    "seed:caro-fitness": "ts-node src/orgs/caro-fitness/main/seed.ts",
    "gen-types": "bash scripts/gen-types.sh",
    "build:deps": "npm run build -w @marketing-funnel/catalog && npm run build -w @marketing-funnel/clickup-client && npm run build -w @marketing-funnel/config && npm run build -w @marketing-funnel/db && npm run build -w @marketing-funnel/elevenlabs && npm run build -w @marketing-funnel/email && npm run build -w @marketing-funnel/whatsapp-client",
    "build": "npm run build:deps && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@marketing-funnel/catalog": "*",
    "@marketing-funnel/clickup-client": "*",
    "@marketing-funnel/config": "*",
    "@marketing-funnel/db": "*",
    "@marketing-funnel/elevenlabs": "*",
    "@marketing-funnel/email": "*",
    "@marketing-funnel/whatsapp-client": "*",
    "@whop/sdk": "^0.0.39",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pg": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.11.0",
    "supabase": "^2.76.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
