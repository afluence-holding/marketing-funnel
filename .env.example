# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct DB connection (for future Drizzle ORM migrations)
DATABASE_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Resend (email)
RESEND_API_KEY=re_your-api-key

# WhatsApp Cloud API (optional)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_TOKEN=
WHATSAPP_BUSINESS_ID=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_BASE_URL=

# ElevenLabs Conversational AI (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=

# API
PORT=3000
NODE_ENV=development

# Project-1 IDs (populated by: npm run seed -w @marketing-funnel/api)
PROJECT1_ORG_ID=
PROJECT1_FUNNEL_ID=
PROJECT1_STAGE_NEW_LEAD=
PROJECT1_STAGE_CONTACTED=
PROJECT1_STAGE_QUALIFIED=
PROJECT1_STAGE_CONVERTED=

# Web (Next.js reads NEXT_PUBLIC_ vars)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
