# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct DB connection (for future Drizzle ORM migrations)
DATABASE_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Resend (email)
RESEND_API_KEY=re_your-api-key

# WhatsApp Cloud API (optional)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_TOKEN=
WHATSAPP_BUSINESS_ID=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_BASE_URL=

# ElevenLabs Conversational AI (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=

# API
PORT=3000
NODE_ENV=development

# Admin dashboard scheduled pulls (optional).
# Set both in the `api` service to enable hourly Meta Ads refreshes:
#   - admin-pull-today        hourly (0 * * * *)
#   - admin-pull-recent       3x/day (0 6,14,22 * * *)
#   - admin-pull-token-health daily  (0 3 * * *)
# ADMIN_URL must point to the deployed admin app (e.g. https://afluence-admin.up.railway.app).
# CRON_SECRET must match the same var set on the admin service.
ADMIN_URL=
CRON_SECRET=

# Project-1 IDs (populated by: npm run seed -w @marketing-funnel/api)
PROJECT1_ORG_ID=
PROJECT1_PIPELINE_ID=
PROJECT1_STAGE_NEW_LEAD=
PROJECT1_STAGE_CONTACTED=
PROJECT1_STAGE_QUALIFIED=
PROJECT1_STAGE_CONVERTED=

# Lucas con Lucas (populate by running: npm run seed:lucas-con-lucas -w @marketing-funnel/api)
LUCAS_CON_LUCAS_ORG_ID=
# Optional token for CSV export: /api/orgs/lucas-con-lucas/bus/main/export?format=csv&token=...
LUCAS_CON_LUCAS_EXPORT_TOKEN=
# Meta Pixel + CAPI Lucas con Lucas (webinar, reto, pre-launch)
# NEXT_PUBLIC_* va en el deploy de web; META_* en el deploy de API. Usa el mismo Pixel ID en ambos.
# Token CAPI: Meta Events Manager → Pixel → Settings → Conversions API → Generate access token
# Opcional para testear en Events Manager antes de producción:
# META_CAPI_TEST_EVENT_CODE=
META_PIXEL_ID_LUCAS_CON_LUCAS=
META_CAPI_TOKEN_LUCAS_CON_LUCAS=
NEXT_PUBLIC_META_PIXEL_LUCAS_CON_LUCAS=
# Reto price tier (CLP) — early bird 77000, preventa 110000, lanzamiento 130000
NEXT_PUBLIC_LUCAS_RETO_PRICE=77000
LUCAS_RETO_PRICE=77000
NEXT_PUBLIC_WHOP_LUCAS_RETO_PLAN_ID=plan_aKOjfecUWLzFo
# Whop — embedded checkout + webhook (API)
WHOP_API_KEY=
WHOP_COMPANY_ID=
WHOP_LUCAS_RETO_PLAN_IDS=plan_aKOjfecUWLzFo
WHOP_LUCAS_RETO_PLAN_ID=plan_aKOjfecUWLzFo
# Public site URL for Whop redirect_url (prod: https://marketing.byafluence.com)
LUCAS_RETO_PUBLIC_URL=https://marketing.byafluence.com
# Whop redirect URL (also set in Whop dashboard if using hosted fallback):
# https://marketing.byafluence.com/lucas-con-lucas/reto/gracias?status=success
# Whop webhook (Developer tab → Create Webhook → payment.succeeded, API v1):
# URL: https://YOUR-API.up.railway.app/api/whop/webhook
WHOP_WEBHOOK_SECRET=

# Santi Inversor / Research Offer
# Populate by running: npx ts-node apps/api/src/orgs/santi-inversor/research/seed.ts
SANTI_INVERSOR_ORG_ID=
SANTI_INVERSOR_PIPELINE_ID=
SANTI_INVERSOR_STAGE_NEW_LEAD=
SANTI_INVERSOR_STAGE_CONTACTED=
SANTI_INVERSOR_STAGE_QUALIFIED=
SANTI_INVERSOR_STAGE_SOLD=
SANTI_INVERSOR_STAGE_LOST=
# Optional token to protect Santi Inversor exports:
# /api/santi-inversor/research/export?format=csv&token=<SANTI_INVERSOR_EXPORT_TOKEN>
SANTI_INVERSOR_EXPORT_TOKEN=

# Web (Next.js reads NEXT_PUBLIC_ vars)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Bukku Education — persistent lead storage via marketing-funnel/api
# No Supabase vars needed on web; API creates bukku_leads table on startup.
# Optional token to protect /bukku/responses and GET /api/bukku/leads
BUKKU_VIEW_TOKEN=

# Mamá Sin Caos (Afluence) — persistent lead storage via marketing-funnel/api
# API creates marketing.mama_sin_caos_leads in Supabase on startup.
# Optional token to protect /afluence/mama-sin-caos/lista-secreta/responses
MAMA_SIN_CAOS_VIEW_TOKEN=

# Bukku pixels (optional)
NEXT_PUBLIC_META_PIXEL_BUKKU=

NEXT_PUBLIC_GA4_SANTI_INVERSOR=
NEXT_PUBLIC_TIKTOK_PIXEL_SANTI_INVERSOR=

# Recetas Cami waitlist email capture
# Configure a Google Apps Script Web App URL that appends each payload to a Google Sheet.
GOOGLE_SHEETS_WEBHOOK_URL_RECETAS_CAMI=
# Optional CSV export URL (used as persistent read source for totals/exports)
GOOGLE_SHEETS_CSV_URL_RECETAS_CAMI=
# Optional token to protect email exports:
# /api/recetas-cami/emails?format=csv&token=<RECETAS_CAMI_EXPORT_TOKEN>
RECETAS_CAMI_EXPORT_TOKEN=
