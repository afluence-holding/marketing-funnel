{
  "name": "marketing-funnel",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @marketing-funnel/api",
    "dev:web": "npm run dev -w @marketing-funnel/web",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afluence-holding/marketing-funnel.git"
  },
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
